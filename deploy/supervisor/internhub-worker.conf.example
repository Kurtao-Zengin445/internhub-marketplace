[program:internhub-worker]
process_name=%(program_name)s_%(process_num)02d
command=php /var/www/internhub/artisan queue:work database --sleep=3 --tries=3 --timeout=90
autostart=true
autorestart=true
stopasgroup=true
killasgroup=true
user=ubuntu
numprocs=1
redirect_stderr=true
stdout_logfile=/var/www/internhub/storage/logs/worker.log
stopwaitsecs=3600
